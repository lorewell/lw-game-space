# ============================================
# Server 环境变量
# ============================================

# 服务器端口
PORT=3000

# MongoDB 连接地址
# 本地开发: mongodb://localhost:27017/lw-game-space
# Docker 部署: mongodb://mongo:27017/lw-game-space
MONGO_URI=mongodb://localhost:27017/lw-game-space

# Redis 连接配置
# 本地开发
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# Docker 部署时 REDIS_HOST=redis, REDIS_URL=redis://redis:6379

# ============================================
# Client 环境变量 (Vite 需要 VITE_ 前缀)
# ============================================

# API 基础地址
VITE_API_BASE_URL=http://localhost:3000

# WebSocket 服务器地址
VITE_WS_URL=ws://localhost:3000
